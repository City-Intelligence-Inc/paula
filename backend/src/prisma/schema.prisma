generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  role         String            @default("PARENT") // ADMIN, TUTOR, PARENT
  firstName    String
  lastName     String
  phone        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  families         FamilyMember[]
  tutoredSessions  Session[]         @relation("TutorSessions")
  tutorAssignments TutorAssignment[]
}

model Student {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  gradeLevel  String
  notes       String?  // internal admin-only notes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  families         FamilyStudent[]
  sessions         Session[]
  tutorAssignments TutorAssignment[]
}

model Family {
  id               String   @id @default(cuid())
  name             String
  stripeCustomerId String?
  billingEmail     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members  FamilyMember[]
  students FamilyStudent[]
  packages Package[]
  payments Payment[]
}

model FamilyMember {
  id       String @id @default(cuid())
  userId   String
  familyId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId])
}

model FamilyStudent {
  id        String @id @default(cuid())
  studentId String
  familyId  String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  family  Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([studentId, familyId])
}

model Package {
  id                   String   @id @default(cuid())
  familyId             String
  name                 String
  sessionCount         Int
  priceInCents         Int
  billingInterval      String   // WEEKLY, BIWEEKLY, MONTHLY
  isActive             Boolean  @default(true)
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Session {
  id          String   @id @default(cuid())
  studentId   String
  tutorId     String
  scheduledAt DateTime
  duration    Int      // minutes
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())

  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor   User          @relation("TutorSessions", fields: [tutorId], references: [id], onDelete: Cascade)
  notes   SessionNote[]
}

model SessionNote {
  id        String   @id @default(cuid())
  sessionId String
  type      String   // INTERNAL, CLIENT
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Payment {
  id                    String   @id @default(cuid())
  familyId              String
  amountInCents         Int
  stripePaymentIntentId String?
  status                String   @default("PENDING") // PENDING, SUCCEEDED, FAILED
  paidAt                DateTime?
  createdAt             DateTime @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model TutorAssignment {
  id        String @id @default(cuid())
  tutorId   String
  studentId String

  tutor   User    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([tutorId, studentId])
}
